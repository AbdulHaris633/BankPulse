# =============================================================================
# ADSPOWER
# =============================================================================
# API key for AdsPower browser automation (found in AdsPower app settings)
ADSPOWER_API_KEY=your_adspower_api_key_here

# Port AdsPower local API runs on (default is 50325, change only if customized)
ADSPOWER_PORT=50325

# =============================================================================
# CAPTCHA SOLVERS
# =============================================================================
# API key for 2Captcha service (used for image/recaptcha/hcaptcha solving)
TWOCAPTCHA_API_KEY=your_twocaptcha_api_key_here

# API key for AntiCaptcha service (fallback captcha solver when 2Captcha fails)
ANTICAPTCHA_API_KEY=your_anticaptcha_api_key_here

# =============================================================================
# COMMAND SERVER
# =============================================================================
# Base URL of the remote server that sends bot instructions
COMMAND_BASE_URL=https://server1.tradingbot.top/

# =============================================================================
# APP BEHAVIOUR
# =============================================================================
# Server ID for this machine (used in logs to identify which server sent them)
SERVER_ID=0

# Set to true if this machine handles payout operations (changes which server
# endpoints are used for instructions and reporting)
PAYOUT_SERVER=false

# Set to true for local development — prints logs to console instead of Datadog
DEBUG_APP=true

# Set to true to use test server endpoints for sync operations
TEST_SERVER=false

# Set to true to include DEBUG level messages in logs (very verbose)
VERBOSE=true

# Set to true to send logs to Datadog (should be false when DEBUG_APP=true)
REMOTE_LOGGING=true

# HTTP request timeout in seconds for all outbound requests
REQUESTS_TIMEOUT=30

# Application name tag used in logs
APP_NAME=BP2PB

# =============================================================================
# DATADOG LOGGING
# =============================================================================
# Datadog API key for remote log ingestion (only used when REMOTE_LOGGING=true)
DD_API_KEY=your_datadog_api_key_here

# =============================================================================
# MYSQL DATABASE
# =============================================================================
# Used to store browser info and command history
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB_NAME=
MYSQL_USER=
MYSQL_PASS=

# =============================================================================
# GOLOGIN (OPTIONAL)
# =============================================================================
# Set to true to enable GoLogin browser profile support alongside AdsPower
ENABLE_GOLOGIN=false

# GoLogin API token (only needed if ENABLE_GOLOGIN=true)
GL_TOKEN=

# =============================================================================
# PROXY PROVIDERS
# =============================================================================
# Leave HOST (or USER for Proxy302) blank to disable a provider entirely.

# Proxy302 — https://proxy302.apifox.cn/
# API-based dynamic rotating proxy. Credentials are fetched via REST API.
# PROXY302_PROTOCOL: socks5 or http
# PROXY302_COUNTRY_ID: country ID from their area API (India = 101)
# PROXY302_STATE_ID / CITY_ID: 0 = any
PROXY302_USER=
PROXY302_PASS=
PROXY302_PROTOCOL=socks5
PROXY302_COUNTRY_ID=101
PROXY302_STATE_ID=0
PROXY302_CITY_ID=0
